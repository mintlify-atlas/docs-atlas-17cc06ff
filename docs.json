{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Mintlify Starter Kit",
  "theme": "mint",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/flan02/docs"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/flan02/docs"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
